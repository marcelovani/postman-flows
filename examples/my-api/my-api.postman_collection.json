{
  "info": {
    "name": "My API — newman-flows example",
    "_postman_id": "example-collection-001",
    "description": "A working example collection for newman-flows.\n\nAll requests live under Requests/ exactly once.\nFlows/ contains flow definitions — each is a FLOW-method request whose pre-request script calls steps([...]).\n\nTo run:\n  npx newman-flows run \"Create and edit item\"\n  npx newman-flows run \"Member invitation\"\n  npx newman-flows run --all",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Requests",
      "description": "Every request is defined exactly once here. Flows reference them by name.",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Admin login",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "login"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Access token present', () => {",
                      "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                      "  pm.globals.set('admin_access_token', json.access_token);",
                      "});",
                      "",
                      "pm.test('User object has required fields', () => {",
                      "  pm.expect(json.user.id).to.be.a('string').and.not.empty;",
                      "  pm.expect(json.user.email).to.be.a('string').and.not.empty;",
                      "});",
                      "",
                      "pm.test('User email looks valid', () => {",
                      "  pm.expect(json.user.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Member login",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"{{member_username}}\",\n  \"password\": \"{{member_password}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "login"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Access token present', () => {",
                      "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                      "  pm.globals.set('member_access_token', json.access_token);",
                      "});",
                      "",
                      "pm.test('Member id stored', () => {",
                      "  pm.expect(json.user.id).to.be.a('string').and.not.empty;",
                      "  pm.globals.set('member_id', json.user.id);",
                      "  pm.globals.set('member_email', json.user.email);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Items",
          "item": [
            {
              "name": "Create Item",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Test item\",\n  \"status\": \"active\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/items",
                  "host": ["{{base_url}}"],
                  "path": ["api", "items"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Response has an id', () => {",
                      "  pm.expect(json.id).to.be.a('string').and.not.empty;",
                      "  pm.globals.set('item_id', json.id);",
                      "});",
                      "",
                      "pm.test('Name matches input', () => {",
                      "  pm.expect(json.name).to.equal('Test item');",
                      "});",
                      "",
                      "pm.test('Status is a known value', () => {",
                      "  const validStatuses = ['active', 'inactive', 'pending'];",
                      "  pm.expect(validStatuses).to.include(json.status);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Edit Item",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Test item (updated)\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/items/{{item_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "items", "{{item_id}}"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Name was updated', () => {",
                      "  pm.expect(json.name).to.equal('Test item (updated)');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "View Item",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_access_token}}" }],
                "url": {
                  "raw": "{{base_url}}/api/items/{{item_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "items", "{{item_id}}"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('ID matches created item', () => {",
                      "  pm.expect(json.id).to.equal(pm.globals.get('item_id'));",
                      "});",
                      "",
                      "pm.test('Name reflects the edit', () => {",
                      "  pm.expect(json.name).to.equal('Test item (updated)');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "List Items",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_access_token}}" }],
                "url": {
                  "raw": "{{base_url}}/api/items",
                  "host": ["{{base_url}}"],
                  "path": ["api", "items"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Response is a non-empty array', () => {",
                      "  pm.expect(json).to.be.an('array').that.is.not.empty;",
                      "});",
                      "",
                      "pm.test('Each record has id and name', () => {",
                      "  json.forEach((record) => {",
                      "    pm.expect(record.id).to.be.a('string').and.not.empty;",
                      "    pm.expect(record.name).to.be.a('string').and.not.empty;",
                      "  });",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Invitations",
          "item": [
            {
              "name": "Invite Member",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{member_username}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/items/{{item_id}}/invitations",
                  "host": ["{{base_url}}"],
                  "path": ["api", "items", "{{item_id}}", "invitations"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Invitation id stored', () => {",
                      "  pm.expect(json.id).to.be.a('string').and.not.empty;",
                      "  pm.globals.set('invitation_id', json.id);",
                      "});",
                      "",
                      "pm.test('Invitee email matches the member we invited', () => {",
                      "  pm.expect(json.invitee_email).to.equal(pm.globals.get('member_email'));",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Accept Invitation",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{member_access_token}}" }],
                "url": {
                  "raw": "{{base_url}}/api/invitations/{{invitation_id}}/accept",
                  "host": ["{{base_url}}"],
                  "path": ["api", "invitations", "{{invitation_id}}", "accept"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Status is accepted', () => {",
                      "  pm.expect(json.status).to.equal('accepted');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Members",
          "item": [
            {
              "name": "View Members",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_access_token}}" }],
                "url": {
                  "raw": "{{base_url}}/api/items/{{item_id}}/members",
                  "host": ["{{base_url}}"],
                  "path": ["api", "items", "{{item_id}}", "members"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "",
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Response is an array', () => {",
                      "  pm.expect(json).to.be.an('array');",
                      "});",
                      "",
                      "pm.test('Invited member appears in members list', () => {",
                      "  const ids = json.map((m) => m.id);",
                      "  pm.expect(ids).to.include(pm.globals.get('member_id'));",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Flows",
      "description": "Flow definitions. Each FLOW request lists the ordered steps in its pre-request script. Run with: npx newman-flows run \"<flow name>\"",
      "item": [
        {
          "name": "Create and edit item",
          "request": {
            "method": "FLOW",
            "url": { "raw": "about:blank", "host": ["about:blank"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Single-persona flow: admin logs in, creates an item, edits it, and views it.",
                  "// Run: npx newman-flows run \"Create and edit item\"",
                  "steps([",
                  "  'Admin login',  // sets admin_access_token",
                  "  'Create Item',  // uses admin_access_token → sets item_id",
                  "  'Edit Item',    // uses admin_access_token + item_id",
                  "  'View Item',    // uses admin_access_token + item_id — asserts name reflects edit",
                  "]);"
                ]
              }
            }
          ]
        },
        {
          "name": "Member invitation",
          "request": {
            "method": "FLOW",
            "url": { "raw": "about:blank", "host": ["about:blank"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Multi-persona flow: admin creates an item and invites a member;",
                  "// member logs in and accepts; admin verifies the member list.",
                  "// Run: npx newman-flows run \"Member invitation\"",
                  "steps([",
                  "  'Admin login',       // sets admin_access_token",
                  "  'Member login',      // sets member_access_token + member_id + member_email",
                  "  'Create Item',       // uses admin_access_token → sets item_id",
                  "  'Invite Member',     // uses admin_access_token + item_id + member_email → sets invitation_id",
                  "  'Accept Invitation', // uses member_access_token + invitation_id",
                  "  'View Members',      // uses admin_access_token + item_id — asserts member_id appears",
                  "]);"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
