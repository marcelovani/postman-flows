{
  "name": "newman-flows",
  "version": "0.1.0",
  "description": "Multi-step Postman flow runner for the free plan — no Enterprise required. Sits on top of Newman and adds flow orchestration: define ordered sequences of named requests inside your Postman collection, run them with a single CLI command.",
  "keywords": [
    "newman",
    "postman",
    "api-testing",
    "flows",
    "postman-flows",
    "cli"
  ],
  "author": "Marcelo Vani <marcelo@legalconnection.co> (https://github.com/marcelovani)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/marcelovani/newman-flows#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcelovani/newman-flows.git"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "bin": {
    "newman-flows": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "postinstall": "if [ -f .github/scripts/setup_hooks.sh ]; then .github/scripts/setup_hooks.sh; fi",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\" \"*.ts\"",
    "lint:fix": "eslint --fix --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\" \"*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "mock": "tsx test/mock/mock-server.ts",
    "pre-push": "npm run format >/dev/null 2>&1 && npm run lint && npm run typecheck && npm run test:unit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^5.0.0",
    "@types/newman": "^5.3.6",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "express": "^5.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
