{
  "info": {
    "name": "My API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Example Postman collection demonstrating newman-flows.\n\nAll requests live under Requests/ exactly once. The Flows/ folder contains\nflow definitions — each is a FLOW-method request whose pre-request script\ncalls steps([...]) with the ordered step names.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "member_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "organisation_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Requests",
      "item": [
        {
          "name": "Authentication",
          "item": [
            {
              "name": "Organisation admin login",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "login"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Response has access_token', () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('access_token');",
                      "  pm.globals.set('access_token', json.access_token);",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Organisation member login",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"{{member_username}}\",\n  \"password\": \"{{member_password}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "login"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Response has access_token', () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('access_token');",
                      "  pm.globals.set('member_access_token', json.access_token);",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Organisation",
          "item": [
            {
              "name": "Create Organisation",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Test Organisation\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/organisations",
                  "host": ["{{base_url}}"],
                  "path": ["api", "organisations"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                      "pm.test('Response has organisation id', () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('id');",
                      "  pm.globals.set('organisation_id', json.id);",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Edit Organisation",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Test Organisation (updated)\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/organisations/{{organisation_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "organisations", "{{organisation_id}}"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Name was updated', () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.name).to.eql('Test Organisation (updated)');",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "View Organisation",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "url": {
                  "raw": "{{base_url}}/api/organisations/{{organisation_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "organisations", "{{organisation_id}}"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Creator is a member', () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.members).to.be.an('array').that.is.not.empty;",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Invite member",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{member_username}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/organisations/{{organisation_id}}/invitations",
                  "host": ["{{base_url}}"],
                  "path": ["api", "organisations", "{{organisation_id}}", "invitations"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                      "pm.test('Invitation created', () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('id');",
                      "  pm.globals.set('invitation_id', json.id);",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Accept invitation",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{member_access_token}}" }
                ],
                "url": {
                  "raw": "{{base_url}}/api/invitations/{{invitation_id}}/accept",
                  "host": ["{{base_url}}"],
                  "path": ["api", "invitations", "{{invitation_id}}", "accept"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Flows",
      "description": "Flow definitions — each FLOW request lists the ordered steps in its pre-request script. Run with: newman-flows run \"<flow name>\"",
      "item": [
        {
          "name": "Organisation creation",
          "request": {
            "method": "FLOW",
            "url": { "raw": "about:blank", "host": ["about:blank"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Run: newman-flows run \"Organisation creation\"",
                  "steps([",
                  "  'Organisation admin login',",
                  "  'Create Organisation',",
                  "  'Edit Organisation',",
                  "  'View Organisation'",
                  "]);"
                ]
              }
            }
          ]
        },
        {
          "name": "Member invitation",
          "request": {
            "method": "FLOW",
            "url": { "raw": "about:blank", "host": ["about:blank"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Run: newman-flows run \"Member invitation\"",
                  "steps([",
                  "  'Organisation admin login',",
                  "  'Create Organisation',",
                  "  'Organisation member login',",
                  "  'Invite member',",
                  "  'Accept invitation'",
                  "]);"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
